# ──────────────────────────────────────────────
# SISTEMA DE AGUA - Variables de Entorno
# ──────────────────────────────────────────────
# Copia este archivo como .env y completa los valores

# Backend
BACKEND_PORT=3001
NODE_ENV=production

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_agua
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT (cambia esto por una clave secreta segura)
JWT_SECRET=generate-a-random-64-char-string-here
JWT_EXPIRES_IN=24h

# CORS (dominio del frontend)
CORS_ORIGIN=https://tudominio.com

# Frontend
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api
